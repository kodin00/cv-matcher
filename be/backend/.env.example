# Docker: DB lives at /app/data/app.db inside the container (set via docker-compose.yml)
# DATABASE_URL is overridden by docker-compose.yml -- do not change it here for Docker runs
DATABASE_URL=sqlite:///app.db
APP_TOKEN=replace-with-a-generated-uuid-here

# Use the base model (default) or point to the fine-tuned model directory:
# MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
MODEL_NAME=models/finetuned
